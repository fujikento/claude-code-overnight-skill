{
  "default_budget_minutes": 360,

  "cost_budget": {
    "max_cost_usd": 50,
    "warn_at_percent": 80,
    "stop_at_percent": 100,
    "model_routing": {
      "expensive_phases": ["2", "8"],
      "standard_phases": ["1a", "1b", "1c", "5", "7"],
      "cheap_phases": ["6"]
    }
  },

  "agent_concurrency_limit": 3,

  "production_safety": {
    "allow_production": false,
    "safe_url_patterns": ["localhost", "127.0.0.1", "0.0.0.0", "staging", "dev", "local", "test"],
    "check_env_vars": ["DATABASE_URL", "API_URL", "BASE_URL", "NEXT_PUBLIC_API_URL"]
  },

  "pattern_memory_max_entries": 100,

  "phases": {
    "1a": {
      "enabled": true,
      "description": "Infrastructure health check",
      "check_docker": "auto",
      "disk_warning_threshold_percent": 90,
      "log_directories": []
    },
    "1b": {
      "enabled": true,
      "description": "DB operations check",
      "db_type": "auto",
      "check_orphaned_records": true,
      "check_data_quality": true,
      "check_slow_queries": true,
      "max_table_rows_warning": 1000000
    },
    "1c": {
      "enabled": true,
      "description": "API operations test",
      "base_api_url": "auto",
      "health_endpoint": "/api/health",
      "slow_response_threshold_ms": 500,
      "critical_response_threshold_ms": 1000,
      "rate_limit_test_count": 50,
      "load_test_requests": 100,
      "load_test_concurrency": 10,
      "test_auth_bypass": true,
      "test_rate_limit": true,
      "test_concurrent": true,
      "test_load": true,
      "external_service_timeout_seconds": 5
    },
    "2": {
      "enabled": true,
      "description": "Code QA (flow-qa 5-pass)",
      "scan_scope": "full_project",
      "include_medium_severity": true,
      "max_fix_loops": 8
    },
    "3": {
      "enabled": true,
      "description": "Interactive QA",
      "web_url": "auto",
      "login": {
        "url": "/login",
        "email_field": "input[name='email'], input[type='email']",
        "password_field": "input[name='password'], input[type='password']",
        "submit_selector": "button[type='submit']",
        "email": "",
        "password": ""
      },
      "pages": "auto",
      "max_buttons_per_page": 20,
      "skip_destructive_buttons": true,
      "destructive_detection": {
        "keywords": ["delete", "remove", "cancel", "destroy", "drop", "reset", "削除", "キャンセル"],
        "aria_patterns": ["aria-label*=delete", "aria-label*=remove", "aria-label*=destroy"],
        "data_attributes": ["data-destructive", "data-danger", "data-action=delete"],
        "css_patterns": [".btn-danger", ".btn-destructive", ".text-destructive"]
      },
      "test_forms": true,
      "test_toggles": true,
      "test_dead_clicks": true,
      "test_crud": false,
      "crud_config": {
        "create_page": "",
        "list_page": "",
        "edit_page": "",
        "test_data": {},
        "cleanup_failure_action": "log_orphan_ids"
      },
      "journeys": [],
      "test_error_pages": true,
      "injection_test_payloads": {
        "xss": [
          "<script>alert('xss')</script>",
          "<img src=x onerror=alert('xss')>"
        ],
        "sqli": [
          "' OR '1'='1",
          "'; DROP TABLE users; --",
          "1 UNION SELECT NULL--"
        ]
      }
    },
    "4": {
      "enabled": true,
      "description": "Design QA",
      "viewports": {
        "desktop": { "width": 1440, "height": 900 },
        "tablet": { "width": 768, "height": 1024 },
        "mobile": { "width": 375, "height": 812 }
      },
      "contrast_threshold_normal": 4.5,
      "contrast_threshold_large": 3.0,
      "min_touch_target_px": 44,
      "check_tokens": true,
      "check_responsive": true,
      "check_accessibility": true,
      "check_component_consistency": true,
      "expert_review": true,
      "figma": {
        "enabled": false,
        "file_key": "",
        "node_ids": {}
      },
      "design_scale": {
        "spacing": [0, 1, 2, 4, 6, 8, 10, 12, 14, 16, 20, 24, 28, 32, 36, 40, 44, 48, 56, 64, 80, 96, 112, 128],
        "border_radius": [0, 2, 4, 6, 8, 12, 16, 9999]
      }
    },
    "5": {
      "enabled": true,
      "description": "Performance QA",
      "bundle_budget_kb": 1000,
      "slow_query_threshold_ms": 100,
      "check_n_plus_one": true,
      "check_bundle_size": true,
      "check_memory_patterns": true
    },
    "6": {
      "enabled": true,
      "description": "Dependency QA",
      "allowed_licenses": [
        "MIT", "Apache-2.0", "BSD-2-Clause", "BSD-3-Clause", "ISC", "0BSD", "Unlicense", "CC0-1.0"
      ],
      "auto_update_patch": true,
      "auto_update_minor": false,
      "auto_update_major": false
    },
    "7": {
      "enabled": true,
      "description": "Documentation QA",
      "check_readme": true,
      "check_api_docs": true,
      "check_stale_todos": true,
      "stale_todo_days": 30,
      "check_internal_links": true
    },
    "8": {
      "enabled": true,
      "description": "Fix & Refactor",
      "auto_fix_severities": ["CRITICAL", "HIGH"],
      "max_fixes_per_run": 20,
      "max_commits": 25,
      "max_lines_changed_per_fix": 50,
      "auto_refactor": false
    },
    "9": {
      "enabled": true,
      "description": "E2E regression check (mandatory after Phase 8 fixes)",
      "auto_revert_on_regression": true
    },
    "10": {
      "enabled": true,
      "description": "Learning & Report",
      "reserved_minutes": 30,
      "update_bug_patterns": true,
      "create_lessons": true,
      "trend_history_count": 5,
      "mirror_report_to_main_repo": true
    }
  },

  "safety": {
    "never_modify": [
      "*.lock",
      "*.env",
      "*.env.*",
      "*.env.local",
      "*.env.production",
      "migrations/**",
      "*.migration.*",
      ".github/**",
      "*.pem",
      "*.key",
      "*.cert",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock",
      "Pipfile.lock",
      "poetry.lock",
      "go.sum",
      "Cargo.lock"
    ],
    "require_tests_pass": true,
    "worktree_isolation": true
  },

  "notifications": {
    "on_complete": true,
    "sound": true,
    "method": "auto"
  }
}
