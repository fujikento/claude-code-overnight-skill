{
  "default_budget_minutes": 360,

  "phases": {
    "1a": {
      "enabled": true,
      "description": "インフラ健全性チェック",
      "check_docker": "auto",
      "disk_warning_threshold_percent": 90,
      "log_directories": []
    },
    "1b": {
      "enabled": true,
      "description": "DB運用チェック",
      "db_type": "auto",
      "check_orphaned_records": true,
      "check_data_quality": true,
      "check_slow_queries": true,
      "max_table_rows_warning": 1000000
    },
    "1c": {
      "enabled": true,
      "description": "API運用テスト",
      "base_api_url": "auto",
      "health_endpoint": "/api/health",
      "slow_response_threshold_ms": 500,
      "critical_response_threshold_ms": 1000,
      "rate_limit_test_count": 50,
      "load_test_requests": 100,
      "load_test_concurrency": 10,
      "test_auth_bypass": true,
      "test_rate_limit": true,
      "test_concurrent": true,
      "test_load": true,
      "external_service_timeout_seconds": 5
    },
    "2": {
      "enabled": true,
      "description": "コードQA (flow-qa 5パス)",
      "scan_scope": "full_project",
      "include_medium_severity": true,
      "max_fix_loops": 8
    },
    "3": {
      "enabled": true,
      "description": "インタラクティブQA",
      "web_url": "auto",
      "login": {
        "url": "/login",
        "email_field": "input[name='email'], input[type='email']",
        "password_field": "input[name='password'], input[type='password']",
        "submit_selector": "button[type='submit']",
        "email": "",
        "password": ""
      },
      "pages": "auto",
      "max_buttons_per_page": 20,
      "skip_destructive_buttons": true,
      "destructive_keywords": ["削除", "delete", "remove", "キャンセル", "cancel", "destroy", "drop", "reset"],
      "test_forms": true,
      "test_toggles": true,
      "test_dead_clicks": true,
      "test_crud": false,
      "crud_config": {
        "create_page": "",
        "list_page": "",
        "edit_page": "",
        "test_data": {}
      },
      "journeys": [],
      "test_error_pages": true,
      "xss_test_payloads": [
        "<script>alert('xss')</script>",
        "' OR '1'='1",
        "<img src=x onerror=alert('xss')>"
      ]
    },
    "4": {
      "enabled": true,
      "description": "デザインQA",
      "viewports": {
        "desktop": { "width": 1440, "height": 900 },
        "tablet": { "width": 768, "height": 1024 },
        "mobile": { "width": 375, "height": 812 }
      },
      "contrast_threshold_normal": 4.5,
      "contrast_threshold_large": 3.0,
      "min_touch_target_px": 44,
      "check_tokens": true,
      "check_responsive": true,
      "check_accessibility": true,
      "check_component_consistency": true,
      "expert_review": true,
      "figma": {
        "enabled": false,
        "file_key": "",
        "node_ids": {}
      },
      "design_scale": {
        "spacing": [0, 1, 2, 4, 6, 8, 10, 12, 14, 16, 20, 24, 28, 32, 36, 40, 44, 48, 56, 64, 80, 96, 112, 128],
        "border_radius": [0, 2, 4, 6, 8, 12, 16, 9999]
      }
    },
    "5": {
      "enabled": true,
      "description": "パフォーマンスQA",
      "bundle_budget_kb": 1000,
      "slow_query_threshold_ms": 100,
      "check_n_plus_one": true,
      "check_bundle_size": true,
      "check_memory_patterns": true
    },
    "6": {
      "enabled": true,
      "description": "依存関係QA",
      "allowed_licenses": [
        "MIT", "Apache-2.0", "BSD-2-Clause", "BSD-3-Clause", "ISC", "0BSD", "Unlicense", "CC0-1.0"
      ],
      "auto_update_patch": true,
      "auto_update_minor": false,
      "auto_update_major": false
    },
    "7": {
      "enabled": true,
      "description": "ドキュメントQA",
      "check_readme": true,
      "check_api_docs": true,
      "check_stale_todos": true,
      "stale_todo_days": 30,
      "check_internal_links": true
    },
    "8": {
      "enabled": true,
      "description": "Fix & Refactor",
      "auto_fix_severities": ["CRITICAL", "HIGH"],
      "max_fixes_per_run": 20,
      "max_commits": 30,
      "max_lines_changed_per_fix": 50,
      "max_refactors": 1
    },
    "9": {
      "enabled": true,
      "description": "E2E回帰確認",
      "auto_revert_on_regression": true
    },
    "10": {
      "enabled": true,
      "description": "学習 & レポート",
      "reserved_minutes": 30,
      "update_bug_patterns": true,
      "create_lessons": true,
      "trend_history_count": 5
    }
  },

  "safety": {
    "never_modify": [
      "*.lock",
      "*.env",
      "*.env.*",
      "*.env.local",
      "*.env.production",
      "migrations/**",
      "*.migration.*",
      ".github/**",
      "*.pem",
      "*.key",
      "*.cert",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock",
      "Pipfile.lock",
      "poetry.lock",
      "go.sum",
      "Cargo.lock"
    ],
    "require_tests_pass": true,
    "worktree_isolation": true
  },

  "notifications": {
    "on_complete": true,
    "sound": true,
    "method": "auto"
  }
}
